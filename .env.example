# =============================================================================
# Celljevity Longevity OS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (required)
# Used by: lib/db, drizzle.config.ts, api-server (via connect-pg-simple sessions)
DATABASE_URL=postgresql://user:password@localhost:5432/celljevity

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port for the API server and Vite dev servers (required)
PORT=3000

# Node environment: "development" or "production"
# Controls session cookie security, build optimizations, and Replit plugin loading
NODE_ENV=development

# Express session secret (required in production, optional in development)
# In development, falls back to a default dev secret if not set
SESSION_SECRET=change-me-to-a-random-secret

# -----------------------------------------------------------------------------
# Vite / Frontend
# -----------------------------------------------------------------------------
# Base path prefix for the frontend app and mockup sandbox (required)
# Used as Vite's `base` option for asset URL prefixing
BASE_PATH=/

# -----------------------------------------------------------------------------
# Replit (optional)
# -----------------------------------------------------------------------------
# Replit deployment ID - when set, enables Replit-specific Vite plugins
# (cartographer, dev-banner). Only relevant when running on Replit.
REPL_ID=
